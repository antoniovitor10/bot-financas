TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_USER_IDS=
LOG_LEVEL=info

ORGANIZZE_EMAIL=
ORGANIZZE_TOKEN=
# Alias aceito pelo app se voce preferir esse nome:
ORGANIZZE_API_KEY=
ORGANIZZE_BASE_URL=https://api.organizze.com.br/rest/v2
ORGANIZZE_USER_AGENT=bot-financas/1.0 (seu-email@example.com)

DATABASE_PATH=./data/bot-financas.sqlite
CATALOG_REFRESH_MINUTES=60
CONFIDENCE_THRESHOLD=0.85

# Defaults opcionais para reduzir perguntas quando o parser nao encontrar o campo.
DEFAULT_ACCOUNT_ID=
DEFAULT_CREDIT_CARD_ID=
DEFAULT_CATEGORY_ID=

# OpenRouter: texto/PDF/visao serao usados nas proximas etapas; audio ja fica suportado.
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=qwen/qwen3-30b-a3b-instruct-2507
OPENROUTER_PDF_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_FALLBACK_MODEL=qwen/qwen2.5-vl-72b-instruct
# cloudflare-ai e gratuito para PDF digital; use mistral-ocr em faturas escaneadas se precisar.
OPENROUTER_PDF_ENGINE=cloudflare-ai
# Se o primeiro engine falhar, o bot tenta estes em ordem. mistral-ocr custa $2/1000 paginas.
OPENROUTER_PDF_FALLBACK_ENGINES=native,mistral-ocr

# Audio: use openrouter por padrao quando OPENROUTER_API_KEY existir.
TRANSCRIPTION_PROVIDER=openrouter
OPENROUTER_TRANSCRIPTION_MODEL=openai/whisper-large-v3-turbo

# Fallback opcional para transcricao via OpenAI direto.
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Opcional. Telegram voice em OGG e enviado direto; ffmpeg fica so para formatos nao suportados.
FFMPEG_PATH=ffmpeg

# ── Backend financeiro ──────────────────────────
# "organizze" (padrão) ou "fincontrol"
FINANCE_BACKEND=organizze
# Usado quando FINANCE_BACKEND=fincontrol:
FINCONTROL_API_URL=http://localhost:5068/api
FINCONTROL_EMAIL=
FINCONTROL_PASSWORD=
